# Client (Vite / Ionic)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGc..."

# Stripe recurring Price ID — see docs/BILLING.md step 2.
# Create a recurring Product+Price in the Stripe Dashboard, then paste its
# price_xxx id here. The SubscriptionGate uses this ID to start Checkout.
VITE_STRIPE_PRICE_ID="price_REPLACE_WITH_RECURRING_ID"

# Server-side only (set via supabase secrets, NEVER ship to client)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGc..."
FRA_CRON_SECRET="generate-a-long-random-string"

# Stripe secret key — required by create-checkout and create-portal-session.
# Set via:  supabase secrets set STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_SECRET_KEY="sk_test_..."

# Per-tenant exchange keys live in Supabase Vault — see docs/DEPLOYMENT.md
# vault.fra_hyperliquid_key_<userId>
# vault.fra_okx_secret_<userId>
