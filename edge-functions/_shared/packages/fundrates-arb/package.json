{
  "name": "@jpytrader/fundrates-arb",
  "version": "0.1.0",
  "description": "Drop-in delta-neutral funding rate arbitrage component for Hyperliquid & OKX",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "browser": {
    "fs": false,
    "path": false,
    "os": false
  },
  "types": "dist/types/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "node --loader ts-node/esm node_modules/webpack-cli/bin/cli.js --config webpack.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "@msgpack/msgpack": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "css-loader": "^7.0.0",
    "css-modules-typescript-loader": "^4.0.0",
    "mini-css-extract-plugin": "^2.9.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "keywords": ["funding-rate", "arbitrage", "delta-neutral", "hyperliquid", "okx", "crypto", "trading"],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpytrader/fundrates-arb"
  }
}
