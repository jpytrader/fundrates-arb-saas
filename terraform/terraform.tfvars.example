# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored — never commit real credentials.

# ─── OCI Identity ─────────────────────────────────────────────────────────────
# Found in: OCI Console → Profile → Tenancy
tenancy_ocid = "ocid1.tenancy.oc1..aaaaaaaaXXXXXXXX"

# Found in: OCI Console → Profile → User Settings
user_ocid = "ocid1.user.oc1..aaaaaaaaXXXXXXXX"

# Found in: OCI Console → Profile → API Keys (after adding the key)
fingerprint = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"

# Path to your OCI API private key on the machine running Terraform
private_key_path = "~/.oci/oci_api_key.pem"

# OCI region — e.g. ap-tokyo-1, us-ashburn-1, eu-frankfurt-1
region = "ap-tokyo-1"

# Compartment to create all resources in (root compartment = tenancy_ocid)
compartment_id = "ocid1.compartment.oc1..aaaaaaaaXXXXXXXX"

# Find with: oci iam availability-domain list --compartment-id <tenancy_ocid>
availability_domain = "RKlC:AP-TOKYO-1-AD-1"

# ─── Compute ──────────────────────────────────────────────────────────────────
# Paste the full public key content (not the file path)
ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... user@host"

# Leave blank to auto-resolve latest Ubuntu 22.04 ARM image for your region.
# Or find explicitly: oci compute image list --compartment-id <tenancy_ocid>
#   --operating-system "Canonical Ubuntu" --operating-system-version "22.04"
#   --shape VM.Standard.A1.Flex --sort-by TIMECREATED --sort-order DESC
ubuntu_image_ocid = ""

# ─── Domain ───────────────────────────────────────────────────────────────────
# Root domain for this deployment — subdomains are auto-derived:
#   api.<domain>, studio.<domain>, status.<domain>, metrics.<domain>, coolify.<domain>
domain_name = "arb.example.com"

# Email for Let's Encrypt TLS certificate expiry notifications
letsencrypt_email = "ops@example.com"

# ─── Networking ───────────────────────────────────────────────────────────────
# Restrict SSH access to your static IP in production, e.g. "203.0.113.10/32"
admin_cidr = "0.0.0.0/0"

# ─── Tags ─────────────────────────────────────────────────────────────────────
project_name = "fundrates-arb"
